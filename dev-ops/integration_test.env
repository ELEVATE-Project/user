#User Service Config

# Port on which service runs
APPLICATION_PORT = 3001

# Service environment
APPLICATION_ENV = development

# Host name this service is reachable at (overridden by dev-ops/docker-compose.yml
# to the actual compose service name)
APPLICATION_HOST = user

# Database connectivity url (overridden by dev-ops/docker-compose.yml's
# DEV_DATABASE_URL to point at the postgres service; kept here only as
# a placeholder so a bare `dotenv` load still has something to find)
DEV_DATABASE_URL=postgres://postgres:postgres@postgres:5432/elevate-user

# Token secret to generate access token
ACCESS_TOKEN_SECRET = 'test'

# Token secret to generate refresh token
REFRESH_TOKEN_SECRET = 'refresh-token-secret'

# Kafka hosted server url
KAFKA_URL = localhost:9092

# Kafka group to which consumer belongs
KAFKA_GROUP_ID = userservice

# Kafka topic to consume data from
KAFKA_TOPIC = 'testTopic'

# Kafka topic to push notification data
NOTIFICATION_KAFKA_TOPIC = 'testTopic'

# Cloud storage provider - aws, azure, gcloud or oci (test-only placeholder values below)
CLOUD_STORAGE_PROVIDER = aws
CLOUD_STORAGE_ACCOUNTNAME = AKIAIOSFODNN7EXAMPLE
CLOUD_STORAGE_SECRET = wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
CLOUD_STORAGE_REGION = ap-south-1
CLOUD_STORAGE_BUCKETNAME = ci-test-private-bucket
PUBLIC_ASSET_BUCKETNAME = ci-test-public-bucket
CLOUD_STORAGE_BUCKET_TYPE = private

# Entity management service base path
ENTITY_MANAGEMENT_SERVICE_BASE_URL = 'entity-management'

# Captcha disabled in CI - keeps captcha secret vars optional
CAPTCHA_ENABLE = false

# Internal access token for communicationcation between services via network call
INTERNAL_ACCESS_TOKEN = 'internal-access-token'

#Enable logging of network request
ENABLE_LOG = true

# JWT Access Token expiry In Days
ACCESS_TOKEN_EXPIRY = '1'

# JWT Refresh Token expiry In Days
REFRESH_TOKEN_EXPIRY = '183'

# Redis Host connectivity url
REDIS_HOST = 'redis://localhost:6379'

# Otp expiration time for forgetpassword or registration process
OTP_EXP_TIME = 86400

# Enable email based otp verification for registration process
ENABLE_EMAIL_OTP_VERIFICATION = false

# Api doc url
API_DOC_URL = '/api-doc'

#Enable email for reported issue.
ENABLE_EMAIL_FOR_REPORT_ISSUE = true

#Email id of the support team.
SUPPORT_EMAIL_ID = 'support@xyz.com,team@xyz.com'

#Email template code for reported issue.
REPORT_ISSUE_EMAIL_TEMPLATE_CODE = 'user_issue_reported'

#Internal cache expiry time
INTERNAL_CACHE_EXP_TIME = 86400

#Kafka internal communicationcation
CLEAR_INTERNAL_CACHE = 'userInternal'

APP_NAME = 'user'

REGISTRATION_EMAIL_TEMPLATE_CODE = 'code'

OTP_EMAIL_TEMPLATE_CODE = 'ssss'
REDIS_CACHE_EXP_TIME = 11

EMAIL_ID_ENCRYPTION_KEY="gPrkwT8PBQqw93bUDIOJxXkrvH6oLeGzigjIUwZDeRI="
EMAIL_ID_ENCRYPTION_IV="j7Vy9Lf8ANHpERUgX4a46A=="

ERROR_LOG_LEVEL='silly'
DISABLE_LOG=false

ADMIN_SECRET_CODE=ci-test-admin-secret-code

# Required external service locations - not actually reachable in CI, only
# needed to satisfy envVariables.js's required-var check at boot.
MENTORING_SERVICE_URL = http://localhost:3000
PORTAL_URL = 'http://localhost:4200'
SCHEDULER_SERVICE_HOST = 'http://localhost:4000'
EVENT_ORG_LISTENER_URLS = 'http://localhost:3567/mentoring/v1/organization/eventListener'

